# OpenRouter API settings ( Nous Hermes-3-Llama-3.1-8B )
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-8b

# Deepgram Speech Services (STT and TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_STT_MODEL=nova-2-medical
DEEPGRAM_TTS_MODEL=aura-helios-en

# Twilio Credentials (for Voice Webhook/Media Streams)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15558392001

# SQLite Database Config inside the container mount
SQLITE_DB_PATH=db_data/dental_clinic.sqlite

# Qdrant Config 
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# Server Configuration
PORT=8000
HOST=0.0.0.0
